terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  default = "us-east-1"
}

variable "project_name" {
  default = "django-payment-service"
}

variable "ssh_key_name" {
  description = "Name of the SSH key pair to use for the EC2 instance"
}
